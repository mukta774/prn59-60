# ML Service Configuration
# Copy this file to .env and adjust values as needed

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true

# API Configuration
PORT=5000
HOST=0.0.0.0

# Model Configuration
MODEL_PATH=./models/hesitancy_model.pkl
EXPLAINER_PATH=./models/hesitancy_explainer.pkl
SCALER_PATH=./models/hesitancy_scaler.pkl

# Logging
LOG_LEVEL=INFO

# CORS Configuration (space-separated origins)
CORS_ORIGINS=http://localhost:3000 http://localhost:8000

# Database (for future integration)
# MONGO_URI=mongodb://localhost:27017/vaccine_hesitancy
# DATABASE_NAME=vaccine_hesitancy
