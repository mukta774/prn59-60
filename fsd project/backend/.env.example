# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vaccine_hesitancy?retryWrites=true&w=majority
MONGODB_TEST_URI=mongodb://localhost:27017/vaccine_hesitancy_test

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# Mail (optional, for doctor approvals, user notifications)
MAIL_SERVICE=gmail
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@vaccinehesitancy.in

# ML Service
ML_SERVICE_URL=http://localhost:8000
ML_API_KEY=your_ml_service_key

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
FILE_RETENTION_DAYS=1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# NMC Verification (external API)
NMC_REGISTRY_API_URL=https://nmc-api.example.com
NMC_API_KEY=your_nmc_api_key

# AWS/Cloud Storage (optional for backups)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vaccine-hesitancy-backups
AWS_REGION=ap-south-1

# Monitoring
SENTRY_DSN=
